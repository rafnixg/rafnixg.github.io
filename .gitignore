# Dependencies
node_modules/
bower_components/

# Build outputs (compiled, not source)
# Note: assets/css/tailwind.css IS committed (no build step on deploy)
dist/
.cache/

# Environment & secrets
.env
.env.local
.env.*.local

# Editor & OS
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Python artifacts (build scripts)
__pycache__/
*.py[cod]
venv/
env/
.venv/

# Temporary files
temp/
tmp/
*.tmp
*.bak
*.swp

# Package lock files (keep package-lock.json, ignore others)
yarn.lock
pnpm-lock.yaml
